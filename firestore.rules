rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Contact messages: anyone can create, only authenticated admin can read/update/delete
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emailNotification', 'emailStatus', 'adminEmailStatus', 'autoReplyStatus', 'visitorEmailStatus']);
    }
    
    // Admin user data (if any): only authenticated user can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // CMS collections: anyone can read, only authenticated admin can write
    match /{collection}/{document=**} {
      allow read: if collection != 'contact_messages' && collection != 'users';
      allow write: if request.auth != null && collection != 'contact_messages' && collection != 'users';
    }

    // Fallback: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
